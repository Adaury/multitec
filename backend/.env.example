# Base de datos: SQLite por defecto (desarrollo). Para migrar a PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://usuario:password@localhost:5432/multitec
DATABASE_URL=sqlite:///./multitec.db

JWT_SECRET=change-this-secret-in-production
JWT_ALGORITHM=HS256
# Access token corto (se renueva solo vía /api/auth/refresh); la sesión real la sostiene
# el refresh token (revocable server-side, "Salir" lo invalida de verdad).
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Usuario administrador inicial (creado por app/db/seed.py)
ADMIN_EMAIL=admin@multitec.com
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Administrador

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25

# Membrete de los PDF de Cotización/Factura — ajustar con los datos reales de la empresa.
COMPANY_NAME=Multitec
COMPANY_RNC=
COMPANY_ADDRESS=
COMPANY_PHONE=

# Notificaciones por correo: cotización pendiente de aprobar (a los admins activos),
# ticket asignado (al técnico), factura emitida (al cliente, con el PDF adjunto, si tiene
# correo registrado). Sin SMTP_HOST, los correos solo se registran en el log del servidor
# (modo consola) — no hace falta SMTP real para desarrollar.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@multitec.local
SMTP_USE_TLS=true

# IA local con Ollama (Fase 5b) — gratis, corre en tu PC.
# Instala Ollama (https://ollama.com), luego:
#   ollama pull llama3.2 && ollama pull llava && ollama pull nomic-embed-text
# Si tu GPU da salida corrupta (bug conocido con Vulkan en algunas AMD), corre Ollama con
# OLLAMA_VULKAN=0 para forzar CPU (más lento pero confiable). Ver README.
# Sin esto, los endpoints de IA responden 400 con un mensaje explicativo (no rompen la app).
OLLAMA_HOST=http://localhost:11434
AI_MODEL=llama3.2
AI_VISION_MODEL=llava
AI_EMBEDDING_MODEL=nomic-embed-text

# Alternativa (Fase 5, API de pago): dejar OLLAMA_HOST vacío no alterna proveedor —
# app/ai_engine usa Ollama exclusivamente. Ver README para volver a Claude si se desea.
ANTHROPIC_API_KEY=
